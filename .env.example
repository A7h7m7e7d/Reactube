# Copy to .env and fill in. All optional — without them the app runs in
# local demo mode (data stored in your browser, stickers + uploads still work).

# Supabase (free tier): https://supabase.com → project settings → API
# Use the API URL (https://<project-ref>.supabase.co), NOT the dashboard link.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# GIPHY (free): https://developers.giphy.com — unlocks GIF trending/search
# (Tenor stopped accepting new API clients Jan 2026; VITE_TENOR_API_KEY still
# works if you have a grandfathered key.)
VITE_GIPHY_API_KEY=
